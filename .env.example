# Copy to backend/.env (local) or set these in your host's dashboard.

# --- Environment ---
# "production" enables strict startup checks (rejects default secret / demo users).
ENVIRONMENT=development

# --- Database ---
# Local default is SQLite (no setup). Managed Postgres URLs (postgres://...) are
# auto-normalized to the psycopg2 driver.
DATABASE_URL=sqlite:///./travel.db

# --- Cache ---
# Empty => in-memory cache. For Redis / multi-instance scale:
# REDIS_URL=redis://localhost:6379/0
REDIS_URL=

# --- Auth / security ---
# REQUIRED in production: a long random string. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-in-prod
FORCE_HTTPS=false                 # true behind a TLS-terminating proxy (Render/Railway)
ALLOWED_HOSTS=*                   # set to your domain(s) in prod, comma-separated
ALLOWED_ORIGINS=*                 # set to your frontend origin if calling cross-origin
RATE_LIMIT_AUTH=10                # login/register requests per IP per window
RATE_LIMIT_WRITE=30               # booking/trip requests per IP per window
RATE_LIMIT_WINDOW=60

# Register an account with this email to become the admin (sees the dashboard).
ADMIN_EMAIL=

# --- Listing data source ---
# osm     = real accommodations from OpenStreetMap (no key, default)
# seed    = curated demo catalog (offline)
# amadeus = Amadeus Self-Service hotel offers (real prices; needs keys below)
DATA_PROVIDER=osm
AMADEUS_API_KEY=
AMADEUS_API_SECRET=

# --- Outbound booking / affiliate links ---
BOOKING_PROVIDER=booking          # booking | google | expedia
# Your Booking.com affiliate id (aid=...) to earn commission. Leave blank for plain links.
BOOKING_AFFILIATE_ID=

# --- Seeding ---
AUTO_SEED=true                    # populate the listing catalog on first run
SEED_DEMO_USERS=true              # seed demo login accounts (set false in prod)

# --- LLM provider: stub | openai | anthropic ---
LLM_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
